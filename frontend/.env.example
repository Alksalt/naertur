# Set to "true" to use the in-memory mock pool (5 Møre og Romsdal hikes)
# Set to "false" to call the real FastAPI backend at VITE_API_BASE_URL.
VITE_USE_MOCK=true

# Backend base URL (only consulted when VITE_USE_MOCK=false).
VITE_API_BASE_URL=http://localhost:8000

# Design variant: "moss" (warm fjord scenes, Schibsted Grotesk) or "trail"
# (topographic maps, Bricolage Grotesque + Newsreader italic) or "random"
# (rerolls every page load). URL ?variant= and localStorage override this.
VITE_VARIANT=moss
