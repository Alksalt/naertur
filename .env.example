DATABASE_URL=postgresql+asyncpg://naertur:naertur@localhost:5432/naertur
# MET requires a real identifying contact email per their ToS.
# Validator rejects values containing "example.com" — replace before first run.
MET_USER_AGENT=NaerTur/0.1 your-email@your-domain.no
ADMIN_IMPORT_TOKEN=
MOROTUR_BASE_URL=https://morotur.no
SAFETY_CACHE_MINUTES=45
NVE_CACHE_MINUTES=360
SEARCH_SAFETY_CANDIDATE_LIMIT=10
# Comma-separated list of allowed CORS origins for the PWA frontend.
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
